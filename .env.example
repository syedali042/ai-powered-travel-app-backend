NODE_ENV=development
PORT=3000

# MongoDB Atlas
MONGODB_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/<dbname>?retryWrites=true&w=majority

# Voyage.ai (for embeddings)
VOYAGE_API_KEY=your_voyage_api_key_here
VOYAGE_MODEL=voyage-3.5-lite

# OpenAI (for RAG generation and filter extraction)
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-4o
OPENAI_FAST_MODEL=gpt-4o-mini

# JWT Auth
JWT_SECRET=your_jwt_secret_here_min_32_chars
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=your_refresh_secret_here_min_32_chars

# Google OAuth (optional — leave blank to disable /auth/google)
GOOGLE_CLIENT_ID=your_google_oauth_client_id_here

# CORS (optional — set to your frontend origin in production)
CLIENT_ORIGIN=http://localhost:5173

# ── External API integrations (B10) ──────────────────────────────────────────

# Google Maps Platform (Places, Directions, Geocoding)
# https://console.cloud.google.com/ — enable Maps JavaScript API + Places API
GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here

# OpenWeatherMap — 5-day forecast (free tier: 60 calls/min)
# https://openweathermap.org/api
OPENWEATHER_API_KEY=your_openweathermap_api_key_here

# RateHawk B2B API — hotel search and price estimates
# Apply for partner access at https://www.ratehawk.com/
RATEHAWK_KEY=your_ratehawk_key_here
RATEHAWK_SECRET=your_ratehawk_secret_here

# Currency conversion uses Frankfurter (https://frankfurter.app) — no key required
# Historical weather uses Open-Meteo (https://open-meteo.com) — no key required
