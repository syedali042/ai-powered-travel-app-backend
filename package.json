{
  "name": "ai-powered-travel-app-backend",
  "version": "1.0.0",
  "description": "Backend for AI-powered travel app using MongoDB Atlas, vector search, and Voyage.ai",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "seed": "node src/scripts/seed.js",
    "seed:fresh": "node src/scripts/seed.js --fresh",
    "embed": "node src/scripts/seedAndEmbed.js",
    "embed:fresh": "node src/scripts/seedAndEmbed.js --fresh",
    "update-embeddings": "node src/jobs/embeddingUpdater.js",
    "create-indexes": "node src/scripts/createAtlasIndexes.js",
    "verify-indexes": "node src/scripts/verifyIndexes.js"
  },
  "dependencies": {
    "bcryptjs": "^3.0.3",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "express-validator": "^7.3.2",
    "google-auth-library": "^10.7.0",
    "jsonwebtoken": "^9.0.3",
    "mongoose": "^8.4.0",
    "morgan": "^1.10.0",
    "node-cron": "^4.2.1",
    "openai": "^6.42.0",
    "voyageai": "^0.3.1"
  },
  "devDependencies": {
    "nodemon": "^3.1.3"
  }
}
